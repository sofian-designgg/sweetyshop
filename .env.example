DISCORD_TOKEN=
# Alias acceptés par le bot : BOT_TOKEN, DISCORD_BOT_TOKEN
# Obligatoire pour voir les / : au démarrage le bot enregistre les slash si CLIENT_ID est défini
CLIENT_ID=
# Recommandé : ID du serveur → les / apparaissent tout de suite (sinon global ≈ 1 h)
GUILD_ID=
# Sur Railway : rien à faire, l’enregistrement des / se fait au démarrage si CLIENT_ID est présent
# Pour désactiver : SKIP_SLASH_DEPLOY=1
# Le bot accepte aussi DATABASE_URL ou MONGODB_URI (souvent fourni par Railway + plugin Mongo)
MONGO_URL=mongodb://mongo:27017/sweetyshop
